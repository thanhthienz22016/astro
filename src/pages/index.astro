---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fall in Luv Music — AI Music Production</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --font-display: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }
    * { box-sizing: border-box; }
    body {
      font-family: var(--font-body);
      background-color: #020817;
      color: #cbd5e1;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }
    h1, h2, h3, h4, .font-display { font-family: var(--font-display); }

    /* Noise texture overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 9999;
      opacity: 0.4;
    }

    /* Glow utilities */
    .glow-emerald { box-shadow: 0 0 40px rgba(16, 185, 129, 0.25), 0 0 80px rgba(16, 185, 129, 0.1); }
    .glow-emerald-sm { box-shadow: 0 0 20px rgba(16, 185, 129, 0.2); }
    .glow-text { text-shadow: 0 0 40px rgba(52, 211, 153, 0.6); }

    /* Gradient text */
    .gradient-text {
      background: linear-gradient(135deg, #f8fafc 0%, #34d399 50%, #6ee7b7 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .gradient-text-white {
      background: linear-gradient(180deg, #f8fafc 0%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Animated gradient border */
    .border-gradient {
      position: relative;
      background: linear-gradient(#020817, #020817) padding-box,
                  linear-gradient(135deg, rgba(52,211,153,0.4), rgba(255,255,255,0.05), rgba(52,211,153,0.2)) border-box;
      border: 1px solid transparent;
    }

    /* Hero blob animations */
    @keyframes blob-drift {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(30px, -20px) scale(1.05); }
      66% { transform: translate(-20px, 10px) scale(0.95); }
    }
    @keyframes blob-drift-2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-40px, 20px) scale(1.08); }
      66% { transform: translate(20px, -30px) scale(0.92); }
    }
    .blob-1 { animation: blob-drift 12s ease-in-out infinite; }
    .blob-2 { animation: blob-drift-2 15s ease-in-out infinite; }
    .blob-3 { animation: blob-drift 18s ease-in-out infinite reverse; }

    /* Waveform bars */
    @keyframes wave-bar {
      0%, 100% { height: 4px; }
      50% { height: 100%; }
    }
    .wave-bar { animation: wave-bar ease-in-out infinite; }

    /* Scan line animation for dashboard mockup */
    @keyframes scan {
      0% { transform: translateY(-100%); opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { transform: translateY(800%); opacity: 0; }
    }
    .scan-line { animation: scan 4s ease-in-out infinite; }

    /* Pulse ring */
    @keyframes pulse-ring {
      0% { transform: scale(1); opacity: 0.4; }
      100% { transform: scale(1.8); opacity: 0; }
    }
    .pulse-ring { animation: pulse-ring 2s ease-out infinite; }

    /* Fade-up on scroll */
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up { animation: fade-up 0.7s ease forwards; }
    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }

    /* Card hover */
    .card-hover {
      transition: transform 0.3s cubic-bezier(.22,.68,0,1.2), box-shadow 0.3s ease;
    }
    .card-hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px rgba(16,185,129,0.1);
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #020817; }
    ::-webkit-scrollbar-thumb { background: rgba(52,211,153,0.3); border-radius: 99px; }

    /* Bento grid */
    .bento-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto;
      gap: 1rem;
    }
    .bento-a { grid-column: span 7; grid-row: span 2; }
    .bento-b { grid-column: span 5; }
    .bento-c { grid-column: span 5; }
    .bento-d { grid-column: span 4; }
    .bento-e { grid-column: span 4; }
    .bento-f { grid-column: span 4; }

    @media (max-width: 1024px) {
      .bento-a { grid-column: span 12; grid-row: span 1; }
      .bento-b { grid-column: span 6; }
      .bento-c { grid-column: span 6; }
      .bento-d, .bento-e, .bento-f { grid-column: span 4; }
    }
    @media (max-width: 640px) {
      .bento-grid { grid-template-columns: 1fr; }
      .bento-a, .bento-b, .bento-c, .bento-d, .bento-e, .bento-f { grid-column: span 1; grid-row: span 1; }
    }

    /* Shimmer effect */
    @keyframes shimmer {
      0% { background-position: -400px 0; }
      100% { background-position: 400px 0; }
    }
    .shimmer {
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.04) 50%, transparent 100%);
      background-size: 800px 100%;
      animation: shimmer 3s linear infinite;
    }

    /* Equalizer bars in hero mockup */
    .eq-bar:nth-child(1) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0s; }
    .eq-bar:nth-child(2) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0.1s; }
    .eq-bar:nth-child(3) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0.2s; }
    .eq-bar:nth-child(4) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0.3s; }
    .eq-bar:nth-child(5) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0.15s; }
    .eq-bar:nth-child(6) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0.25s; }
    .eq-bar:nth-child(7) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0.05s; }
    .eq-bar:nth-child(8) { animation: wave-bar 0.8s ease-in-out infinite; animation-delay: 0.35s; }
  </style>
</head>
<body class="scroll-smooth">

<!-- ═══════════════════════════════════════════
     NAVBAR
═══════════════════════════════════════════ -->
<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-slate-950/70 border-b border-white/[0.06]">
  <div class="max-w-7xl mx-auto px-5 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2.5 group">
      <div class="relative w-8 h-8 flex-shrink-0">
        <div class="absolute inset-0 bg-emerald-500 rounded-lg opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M3 13.5 Q5 9 9 4.5 Q13 9 15 13.5" stroke="#34d399" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <circle cx="9" cy="9" r="2" fill="#34d399"/>
            <path d="M1 13.5 L17 13.5" stroke="#34d399" stroke-width="0.75" opacity="0.4"/>
          </svg>
        </div>
      </div>
      <span class="font-display font-700 text-slate-50 text-[15px] tracking-tight">Fall in Luv<span class="text-emerald-400"> Music</span></span>
    </a>

    <!-- Nav links (desktop) -->
    <div class="hidden md:flex items-center gap-1">
      <a href="#features" class="px-4 py-2 text-sm text-slate-400 hover:text-slate-200 transition-colors rounded-lg hover:bg-white/5">Features</a>
      <a href="#deep-dive" class="px-4 py-2 text-sm text-slate-400 hover:text-slate-200 transition-colors rounded-lg hover:bg-white/5">Technology</a>
      <a href="#pricing" class="px-4 py-2 text-sm text-slate-400 hover:text-slate-200 transition-colors rounded-lg hover:bg-white/5">Pricing</a>
      <a href="#testimonials" class="px-4 py-2 text-sm text-slate-400 hover:text-slate-200 transition-colors rounded-lg hover:bg-white/5">Reviews</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <a href="#" class="hidden md:block text-sm text-slate-400 hover:text-slate-200 transition-colors px-3 py-2">Sign in</a>
      <a href="#pricing" class="relative group px-4 py-2 rounded-lg text-sm font-medium text-white overflow-hidden glow-emerald-sm transition-all hover:scale-105">
        <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-emerald-500 rounded-lg"></div>
        <div class="absolute inset-0 shimmer rounded-lg"></div>
        <span class="relative">Get Started →</span>
      </a>
    </div>
  </div>
</nav>


<!-- ═══════════════════════════════════════════
     HERO
═══════════════════════════════════════════ -->
<section class="relative min-h-screen flex flex-col items-center justify-center pt-24 pb-12 px-5 overflow-hidden">

  <!-- Background ambient blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="blob-1 absolute top-[15%] left-[10%] w-[500px] h-[500px] bg-emerald-500/[0.07] rounded-full blur-[120px]"></div>
    <div class="blob-2 absolute top-[30%] right-[5%] w-[400px] h-[400px] bg-teal-400/[0.06] rounded-full blur-[100px]"></div>
    <div class="blob-3 absolute bottom-[10%] left-[40%] w-[600px] h-[300px] bg-emerald-600/[0.05] rounded-full blur-[140px]"></div>
    <!-- Grid lines -->
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <!-- Radial fade over grid -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 50% at 50% 30%, transparent 30%, #020817 80%);"></div>
  </div>

  <!-- Badge -->
  <div class="relative z-10 mb-6 animate-fade-up flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-4 py-1.5">
    <span class="relative flex h-2 w-2">
      <span class="pulse-ring absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-40"></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
    </span>
    <span class="text-xs text-emerald-300 font-medium tracking-wide">Now in open beta — 10,000 producers onboard</span>
  </div>

  <!-- Headline -->
  <div class="relative z-10 text-center max-w-5xl mx-auto">
    <h1 class="animate-fade-up delay-100 font-display font-800 text-5xl sm:text-7xl lg:text-8xl tracking-tighter leading-[0.92] mb-6">
      <span class="gradient-text-white">Remix the</span><br />
      <span class="gradient-text">future of sound.</span>
    </h1>
    <p class="animate-fade-up delay-200 text-slate-400 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed mb-10">
      The ultimate AI co-producer. Stem separation, instant tempo sync, and vocal processing engineered for modern beatmakers.
    </p>

    <!-- CTAs -->
    <div class="animate-fade-up delay-300 flex flex-col sm:flex-row items-center justify-center gap-3 mb-16">
      <a href="#pricing" class="relative group px-7 py-3.5 rounded-xl text-base font-medium text-white overflow-hidden glow-emerald transition-all hover:scale-105 w-full sm:w-auto text-center">
        <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 via-emerald-500 to-teal-500 rounded-xl"></div>
        <div class="absolute inset-0 shimmer rounded-xl"></div>
        <span class="relative flex items-center justify-center gap-2">
          Start Producing Free
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
      <a href="#features" class="group px-7 py-3.5 rounded-xl text-base font-medium text-slate-300 bg-white/[0.04] border border-white/[0.08] backdrop-blur-sm hover:bg-white/[0.07] hover:text-white transition-all w-full sm:w-auto text-center">
        <span class="flex items-center justify-center gap-2">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.25"/><path d="M6.5 6.5C6.5 5.67 7.17 5 8 5s1.5.67 1.5 1.5c0 .7-.45 1.28-1.08 1.43L8 8v1.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/><circle cx="8" cy="11.5" r="0.5" fill="currentColor"/></svg>
          See how it works
        </span>
      </a>
    </div>

    <!-- Dashboard Mockup -->
    <div class="animate-fade-up delay-400 relative max-w-4xl mx-auto">
      <!-- Glow behind mockup -->
      <div class="absolute -inset-10 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -inset-4 bg-teal-400/5 rounded-3xl blur-2xl pointer-events-none"></div>

      <!-- Main mockup container -->
      <div class="relative border-gradient rounded-2xl overflow-hidden shadow-2xl" style="box-shadow: 0 40px 120px rgba(0,0,0,0.7), 0 0 60px rgba(16,185,129,0.08), inset 0 1px 0 rgba(255,255,255,0.06);">

        <!-- Window chrome -->
        <div class="flex items-center justify-between px-5 py-3.5 bg-slate-900/90 border-b border-white/[0.06]">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-500/70"></div>
          </div>
          <div class="flex items-center gap-2 bg-slate-800/80 rounded-md px-3 py-1">
            <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><circle cx="5" cy="5" r="3.5" stroke="#64748b" stroke-width="1.2"/><path d="M8 8l2.5 2.5" stroke="#64748b" stroke-width="1.2" stroke-linecap="round"/></svg>
            <span class="text-slate-500 text-xs">app.fallinluvmusic.io</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-4 h-4 bg-emerald-500/20 rounded flex items-center justify-center">
              <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
            </div>
            <span class="text-xs text-emerald-400 font-medium">LIVE</span>
          </div>
        </div>

        <!-- Dashboard body -->
        <div class="bg-slate-950/95 p-5">
          <!-- Top track bar -->
          <div class="flex items-center gap-4 mb-5">
            <div class="flex items-center gap-2 bg-slate-800/60 rounded-lg px-3 py-2 flex-1">
              <div class="w-8 h-8 rounded-md bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center flex-shrink-0">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 9 Q4 3 6 1 Q8 3 10 9" stroke="white" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>
              </div>
              <div>
                <div class="text-xs text-slate-200 font-medium">Track_01_vocal_main.wav</div>
                <div class="text-xs text-slate-500">4:32 • 44.1kHz • 24bit</div>
              </div>
            </div>
            <div class="flex items-center gap-1.5 flex-shrink-0">
              <button class="w-7 h-7 rounded-md bg-slate-800/60 flex items-center justify-center">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 2v6M3.5 5l4.5-3v6l-4.5-3z" fill="#94a3b8"/></svg>
              </button>
              <button class="w-9 h-9 rounded-lg bg-emerald-500 flex items-center justify-center glow-emerald-sm">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 2.5v7l7-3.5-7-3.5z" fill="white"/></svg>
              </button>
              <button class="w-7 h-7 rounded-md bg-slate-800/60 flex items-center justify-center">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M8 2v6M2 5l4.5 3V2L2 5z" fill="#94a3b8"/></svg>
              </button>
            </div>
            <div class="text-xs text-slate-400 flex-shrink-0 hidden sm:block">BPM <span class="text-emerald-400 font-medium font-display">128</span></div>
            <div class="text-xs text-slate-400 flex-shrink-0 hidden sm:block">KEY <span class="text-emerald-400 font-medium font-display">Am</span></div>
          </div>

          <!-- Waveform / stems area -->
          <div class="grid grid-rows-4 gap-1.5 mb-5">
            <!-- Stem rows -->
            <div class="flex items-center gap-2 h-10">
              <div class="w-14 flex-shrink-0 text-right">
                <span class="text-xs text-emerald-400 font-medium">VOCAL</span>
              </div>
              <div class="flex-1 h-full bg-slate-900/60 rounded-md overflow-hidden relative border border-white/[0.04]">
                <div class="absolute inset-0" style="background: repeating-linear-gradient(90deg, rgba(52,211,153,0.5) 0px, rgba(52,211,153,0.3) 2px, rgba(52,211,153,0.1) 3px, transparent 4px, rgba(52,211,153,0.2) 6px, rgba(52,211,153,0.4) 8px, transparent 10px, transparent 12px); height: 100%; opacity: 0.6;"></div>
                <div class="scan-line absolute inset-x-0 h-0.5 bg-gradient-to-r from-transparent via-emerald-400/60 to-transparent top-0"></div>
              </div>
              <div class="w-6 h-6 rounded-md bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center flex-shrink-0">
                <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
              </div>
            </div>
            <div class="flex items-center gap-2 h-10">
              <div class="w-14 flex-shrink-0 text-right">
                <span class="text-xs text-sky-400 font-medium">DRUMS</span>
              </div>
              <div class="flex-1 h-full bg-slate-900/60 rounded-md overflow-hidden relative border border-white/[0.04]">
                <div class="absolute inset-0" style="background: repeating-linear-gradient(90deg, rgba(56,189,248,0.4) 0px, rgba(56,189,248,0.2) 2px, transparent 4px, rgba(56,189,248,0.5) 5px, rgba(56,189,248,0.3) 7px, transparent 9px, transparent 14px, rgba(56,189,248,0.4) 15px, transparent 17px); height: 100%; opacity: 0.7;"></div>
              </div>
              <div class="w-6 h-6 rounded-md bg-sky-500/20 border border-sky-500/30 flex items-center justify-center flex-shrink-0">
                <div class="w-2 h-2 rounded-full bg-sky-400"></div>
              </div>
            </div>
            <div class="flex items-center gap-2 h-10">
              <div class="w-14 flex-shrink-0 text-right">
                <span class="text-xs text-violet-400 font-medium">BASS</span>
              </div>
              <div class="flex-1 h-full bg-slate-900/60 rounded-md overflow-hidden relative border border-white/[0.04]">
                <div class="absolute inset-0" style="background: repeating-linear-gradient(90deg, rgba(139,92,246,0.5) 0px, rgba(139,92,246,0.2) 3px, transparent 6px, rgba(139,92,246,0.4) 10px, rgba(139,92,246,0.1) 13px, transparent 16px); height: 100%; opacity: 0.7;"></div>
              </div>
              <div class="w-6 h-6 rounded-md bg-violet-500/20 border border-violet-500/30 flex items-center justify-center flex-shrink-0">
                <div class="w-2 h-2 rounded-full bg-violet-400"></div>
              </div>
            </div>
            <div class="flex items-center gap-2 h-10">
              <div class="w-14 flex-shrink-0 text-right">
                <span class="text-xs text-amber-400 font-medium">OTHER</span>
              </div>
              <div class="flex-1 h-full bg-slate-900/60 rounded-md overflow-hidden relative border border-white/[0.04]">
                <div class="absolute inset-0" style="background: repeating-linear-gradient(90deg, rgba(251,191,36,0.3) 0px, rgba(251,191,36,0.15) 2px, transparent 5px, rgba(251,191,36,0.4) 8px, transparent 12px, rgba(251,191,36,0.2) 15px, transparent 18px); height: 100%; opacity: 0.6;"></div>
              </div>
              <div class="w-6 h-6 rounded-md bg-amber-500/20 border border-amber-500/30 flex items-center justify-center flex-shrink-0">
                <div class="w-2 h-2 rounded-full bg-amber-400"></div>
              </div>
            </div>
          </div>

          <!-- Bottom EQ + stats row -->
          <div class="flex items-end gap-3">
            <!-- Mini EQ visualizer -->
            <div class="flex items-end gap-px h-10 flex-shrink-0">
              <div class="eq-bar w-1.5 bg-emerald-500 rounded-t-sm min-h-[4px]" style="height: 30%;"></div>
              <div class="eq-bar w-1.5 bg-emerald-500 rounded-t-sm min-h-[4px]" style="height: 65%;"></div>
              <div class="eq-bar w-1.5 bg-emerald-400 rounded-t-sm min-h-[4px]" style="height: 90%;"></div>
              <div class="eq-bar w-1.5 bg-emerald-400 rounded-t-sm min-h-[4px]" style="height: 75%;"></div>
              <div class="eq-bar w-1.5 bg-teal-400 rounded-t-sm min-h-[4px]" style="height: 85%;"></div>
              <div class="eq-bar w-1.5 bg-teal-400 rounded-t-sm min-h-[4px]" style="height: 55%;"></div>
              <div class="eq-bar w-1.5 bg-emerald-500 rounded-t-sm min-h-[4px]" style="height: 40%;"></div>
              <div class="eq-bar w-1.5 bg-emerald-500 rounded-t-sm min-h-[4px]" style="height: 20%;"></div>
            </div>

            <!-- Stats chips -->
            <div class="flex flex-wrap gap-2 flex-1">
